<?xml version="1.0" encoding="utf-8"?>
<project>
    <meta title="Sc Shader generator" package="com.Sc.Render" version="0.0.6" company="Ren" />
    <app main="Main" file="Generator" path="export" />
    <window width="1280" height="720" fps="60" background="#000000" />
    <source path="source" />
    <assets path="assets" rename="assets" />
    <haxelib name="openfl" />
    <haxelib name="flixel" />
	<haxelib name="flixel-tools" />
	<haxelib name="flixel-ui" />
    <icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png" />
	<window if="mobile" orientation="landscape" fullscreen="true" width="1280" height="720" resizable="false"/>
    <section if="android">
	  <config:android permission="android.permission.MANAGE_MEDIA"/> 
	  <config:android permission="android.permission.MANAGE_EXTERNAL_STORAGE"/>
	  <config:android permission="android.permission.WRITE_EXTERNAL_STORAGE" />
	  <config:android permission="android.permission.READ_EXTERNAL_STORAGE" />
	  <config:android permission="android.permission.READ_MEDIA_IMAGES"/>
	  <config:android permission="android.permission.READ_MEDIA_AUDIO"/>
      <config:android permission="android.permission.READ_MEDIA_VIDEO"/>
	  <config:android permission="android.permission.VIBRATE" />
	  <config:android permission="android.permission.INTERNET" />
	  <config:android permission="android.permission.ACCESS_WIFI_STATE"/>
	  <config:android permission="android.permission.ACCESS_NETWORK_STATE" />
	  <config:android permission="android.permission.CAPTURE_AUDIO_OUTPUT" />
	  </section>
</project>
